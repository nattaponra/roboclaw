{
  "name": "@nattaponra/roboclaw-vision",
  "version": "0.1.0",
  "description": "Computer vision capabilities for RoboClaw (YOLO, face recognition, Vision LLM)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "models",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "shx rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "onnxruntime-node": "^1.21.0"
  },
  "peerDependencies": {
    "@nattaponra/roboclaw-core": "^0.1.0",
    "@nattaponra/roboclaw-hardware": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "computer-vision",
    "yolo",
    "object-detection",
    "face-recognition",
    "opencv"
  ],
  "author": "Nattapon Ra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nattaponra/agent.git",
    "directory": "packages/vision"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
